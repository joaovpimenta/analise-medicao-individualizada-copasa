<script>
	window.addEventListener('DOMContentLoaded', function () {
		const anchorUrl = window.location.hash.slice(1); //window.location.hash.substring(1);
		if(!anchorUrl) return;

		const anchorObj = document.getElementsByName(anchorUrl)[0]; //document.querySelector('a[name="'+CSS.escape(anchorUrl)+'"]');			
		if(!anchorObj) return;
		anchorObj.classList.remove("collapsed");

		const anchorId = anchorObj.getAttribute("aria-controls");
		if(!anchorId) return;

		const anchorLink = document.getElementById(anchorId);
		if(anchorLink) anchorLink.classList.add("show");
	});
</script><style>
