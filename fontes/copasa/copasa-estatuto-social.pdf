		<script src="https://cdn.rawgit.com/adamwdraper/Numeral-js/master/locales/pt-br.js"></script>
		<script>
			var MZStockInfo = new MZIQ_StockInfo;
			var langCode = 'pt-br';
			var langCodeFormatted = langCode.split('-')[0];
			var decimalConfig = { minimumFractionDigits: 2, maximumFractionDigits: 2 }
			var decimalConfigVol = { minimumFractionDigits: 0, maximumFractionDigits: 0 }
			var stockInfoId = '08d2c43c-9c29-11e9-863f-0aed8756bb2a'
			numeral.locale(langCode)

			var options = {
				language: langCodeFormatted,
				stockinfoId: stockInfoId,  
				template: {
					type: 'raw'
				},
				rawInit: function(data){
					var ticker = data.tickers[0]
					var ibov = data.indexes[0]

					$('.quotes .csmg3 .ticker').text(ticker.ticker)
					$('.quotes .csmg3 .value').text(numeral(ticker.info.price).format('$00,00.00'))
					$('.quotes .csmg3 .variation').text(numeral(ticker.info.var).format('0.00')+ '%')
					if(ticker.info.var > 0) {
						$('.quotes .csmg3 .variation').addClass('up')
					} else {
						$('.quotes .csmg3 .variation').addClass('down')
					}
					$('.quotes .ibov .ticker').text(ibov.ticker)
					$('.quotes .ibov .value').text(numeral(ibov.info.price).format('0,0'))
					$('.quotes .ibov .variation').text(numeral(ibov.info.var).format('0.00')+ '%')
					if(ibov.info.var > 0) {
						$('.quotes .ibov .variation').addClass('up')
					} else {
						$('.quotes .ibov .variation').addClass('down')
					}
					
					$('#loading-quotes').hide();
					$('.quotes').css("display", "inline-block")
				}
			};

			MZStockInfo.initialize(options);
		</script>
